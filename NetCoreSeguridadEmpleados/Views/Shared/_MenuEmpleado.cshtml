@if (!Context.User.Identity.IsAuthenticated)
{
    //efecto optico del login
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Empleados" asp-action="Perfil">
            Login
        </a>
    </li>
}
else
{
    <ul>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Managed" asp-action="Logout">
                Logout
                <span>@Context.User.Identity.Name</span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Empleados" asp-action="Perfil">
                Mi Perfil
            </a>
        </li>
    </ul>
}